<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ brand_en }} | {{ brand_cn }}</title>
    <link rel="stylesheet" href="/auto-materials-brief/assets/style.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="{{ root_prefix }}/index.html">
        <span>{{ brand_en }}</span>
        <small>{{ brand_cn }}</small>
      </a>
      <nav class="top-nav">
        <span>Researcher's Workspace</span>
      </nav>
    </header>

    <main class="page">
      <section id="studio" class="studio-hero is-3d" aria-labelledby="studio-title">
        <div
          id="auraStudio3d"
          class="studio-3d"
          data-root-prefix="{{ root_prefix }}"
          aria-label="AURA realistic 3D researcher's workspace"
        >
          <div class="studio-3d-loading">
            <span>AURA Studio</span>
            <small>Entering the researcher's workspace</small>
          </div>
        </div>
        <div class="studio-copy">
          <p class="eyebrow">{{ date }}</p>
          <h1 id="studio-title" class="studio-wordmark">
            <span>AURA</span>
            <span>Studio</span>
          </h1>
          <p class="studio-role">Researcher's Workspace</p>
          <p class="studio-expansion">
            Advanced Understanding<br>
            of Research &amp; Applications
          </p>
        </div>
        <div class="studio-hint">Click objects in the room</div>
        <div class="studio-object-label" id="studioObjectLabel" aria-hidden="true"></div>
        <div class="studio-panel" id="studioPanel" aria-live="polite" aria-hidden="true">
          <button class="studio-panel-close" type="button" data-close-studio-panel aria-label="Close studio panel">×</button>
          <div class="studio-panel-content" id="studioPanelContent"></div>
        </div>
        <div class="research-desk studio-fallback" aria-label="Researcher's desk fallback navigation">
          <button class="desk-object desk-window" type="button" data-studio-target="future-signals" aria-label="Open Future Signals">
            <span class="window-frame"><i></i><i></i></span>
            <strong>Window</strong>
            <em>Future Signals</em>
          </button>
          <button class="desk-object desk-notebook" type="button" data-studio-target="key-insight" aria-label="Open Today's Key Insight">
            <span class="notebook-shape"><i></i></span>
            <strong>Notebook</strong>
            <em>Today's Key Insight</em>
          </button>
          <button class="desk-object desk-bookshelf" type="button" data-studio-target="opportunity-graph" aria-label="Open Material Opportunity Graph">
            <span class="bookshelf-shape"><i></i><i></i><i></i><i></i></span>
            <strong>Bookshelf</strong>
            <em>Material Opportunity Graph</em>
          </button>
          <button class="desk-object desk-palette" type="button" data-studio-target="suggested-actions" aria-label="Open Suggested Actions">
            <span class="palette-shape"><i></i><i></i><i></i><i></i></span>
            <strong>Palette</strong>
            <em>Suggested Actions</em>
          </button>
          <button class="desk-object desk-archive" type="button" data-studio-target="archives" aria-label="Open Archive">
            <span class="archive-shape"><i></i></span>
            <strong>Archive Box</strong>
            <em>Archive</em>
          </button>
          <button class="desk-object desk-cat" type="button" data-studio-target="insights" aria-label="Open Weekly Insights">
            <span class="cat-shape"><i></i><i></i></span>
            <strong>Cat</strong>
            <em>Weekly Insights</em>
          </button>
        </div>
      </section>

      <section id="future-signals" class="opportunity-panel radar-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Window</p>
          <h2>Future Signals</h2>
        </div>
        <div class="hotspot-grid">
          {% for radar in future_radar %}
          <article>
            <strong>{{ radar.category }}</strong>
            <span>{{ radar.count }} 条 · Future Signal {{ radar.avg_future_signal_score }} <button class="info-button compact" type="button" data-metric="future_signal_score" aria-label="查看Future Signal说明">ⓘ</button></span>
          </article>
          {% else %}
          <article>
            <strong>暂无独立未来技术信号</strong>
            <span>未来技术模块只在能回答材料机会时展示</span>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="key-insight" class="opportunity-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Notebook</p>
          <h2>Today's Key Insight</h2>
        </div>
        <div class="insight-stack insight-panel">
          {% for row in research_insight_cards %}
          <article>
            <strong>{{ row.label }}</strong>
            <p>{{ row.text }}</p>
          </article>
          {% endfor %}
        </div>
        <div class="highlight-list">
          {% for item in items[:5] %}
          <article>
            <span>{{ item.source }} · {{ item.published_date }}</span>
            <h3><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></h3>
            <p>Material Opportunity <button class="info-button compact" type="button" data-metric="material_opportunity" aria-label="查看Material Opportunity说明">ⓘ</button>: {{ item.material_opportunity }}</p>
            <strong>Suggested Action <button class="info-button compact" type="button" data-metric="suggested_action" aria-label="查看Suggested Action说明">ⓘ</button>: {{ item.suggested_action_en }} / {{ item.suggested_action_zh }}</strong>
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">阅读原文</a>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="opportunity-graph" class="opportunity-panel priority-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Bookshelf</p>
          <h2>Material Opportunity Graph</h2>
        </div>
        <div class="domain-grid">
          {% for domain in opportunity_domains %}
          <article>
            <strong>{{ domain.domain }}</strong>
            <p>{{ domain.zh }}</p>
            <span>{{ domain.news_count }} signals · {{ domain.topic_count }} topics</span>
          </article>
          {% endfor %}
        </div>
        <div class="topic-grid">
          {% for topic in opportunity_topics[:8] %}
          <article>
            <div class="topic-topline">
              <span>{{ topic.domain }}</span>
              <b>{{ topic.validation_priority }} <button class="info-button compact" type="button" data-metric="validation_priority" aria-label="查看Validation Priority说明">ⓘ</button></b>
            </div>
            <h3>{{ topic.topic }}</h3>
            <p>
              Material Value {{ topic.material_value }}
              <button class="info-button compact" type="button" data-metric="material_value" aria-label="查看Material Value说明">ⓘ</button>
              · {{ topic.suggested_action }}
              <button class="info-button compact" type="button" data-metric="suggested_action" aria-label="查看Suggested Action说明">ⓘ</button>
            </p>
            <div class="related-signal-list">
              {% for signal in topic.related_signals %}
              <a href="{{ signal.url }}" target="_blank" rel="noopener noreferrer">{{ signal.title }}</a>
              {% endfor %}
            </div>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="suggested-actions" class="opportunity-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Palette</p>
          <h2>Suggested Actions</h2>
        </div>
        <div class="validation-pool">
          {% for group in validation_pool %}
          <article style="--action-color: {{ group.color }}">
            <h3>{{ group.action }}</h3>
            <span>{% if group.has_new %}<i class="action-dot" aria-label="本周期有新增内容"></i>{% endif %}{{ group.meaning }} · {{ group.count }} 条</span>
            <ul>
              {% for item in group["items"][:4] %}
              <li><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></li>
              {% else %}
              <li>暂无</li>
              {% endfor %}
            </ul>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="insights" class="opportunity-panel insights-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Cat</p>
          <h2>Weekly Insights</h2>
        </div>
        <div class="insights-grid">
          {% for article in insights %}
          <article>
            <div class="insight-meta">{{ article.reading_time }}</div>
            <h3><a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a></h3>
            <p><strong>为什么值得读：</strong>{{ article.why_read }}</p>
            <p><strong>建议关注：</strong>{{ article.focus }}</p>
            <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">阅读全文</a>
          </article>
          {% else %}
          <article>
            <div class="insight-meta">待补充</div>
            <h3>Insights 内容池尚未配置</h3>
            <p><strong>为什么值得读：</strong>该模块用于沉淀帮助研发人员理解变化背后原因的深度文章。</p>
            <p><strong>建议关注：</strong>后续可从本地 JSON 或自动化来源补充精选内容。</p>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="archives" class="archive-grid studio-content-source">
        <div>
          <p class="eyebrow">Archive</p>
          <h2>Daily Archive</h2>
          <div class="archive-links">
            {% for item in archives.daily %}
            <a href="{{ item.href }}">{{ item.date }}</a>
            {% endfor %}
          </div>
        </div>
        <div>
          <p class="eyebrow">Monthly</p>
          <h2>Monthly Archive</h2>
          <div class="archive-links">
            {% for item in archives.monthly %}
            <a href="{{ item.href }}">{{ item.month }}</a>
            {% endfor %}
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <strong>{{ brand_en }}</strong>
      <span>{{ brand_full_en }}</span>
    </footer>

    <script>
      window.AURA = { generatedAt: "{{ date }}" };
    </script>
    <script>
      (() => {
        const panel = document.getElementById("studioPanel");
        const panelContent = document.getElementById("studioPanelContent");
        const sources = new Map(
          [...document.querySelectorAll(".studio-content-source")].map((node) => [node.id, node])
        );
        if (!panel || !panelContent) return;

        const openPanel = (target) => {
          const source = sources.get(target);
          if (!source) return;
          panelContent.innerHTML = source.innerHTML;
          panel.dataset.source = target;
          panel.classList.add("is-open");
          panel.setAttribute("aria-hidden", "false");
        };

        const closePanel = () => {
          panel.classList.remove("is-open");
          panel.setAttribute("aria-hidden", "true");
        };

        window.AURAStudioOpenPanel = openPanel;
        document.querySelectorAll("[data-studio-target]").forEach((button) => {
          button.addEventListener("click", () => openPanel(button.dataset.studioTarget));
        });
        document.querySelector("[data-close-studio-panel]")?.addEventListener("click", closePanel);
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") closePanel();
        });
      })();
    </script>
    <script type="module" src="{{ asset_prefix }}/studio3d.js?v=20260623-cat-sleeping"></script>
    {% include "_metric_modal.html.j2" %}
  </body>
</html>
