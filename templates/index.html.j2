<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ brand_en }}</title>
    <link rel="stylesheet" href="/auto-materials-brief/assets/style.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="{{ root_prefix }}/index.html">
        <span>{{ brand_en }}</span>
      </a>
      <nav class="top-nav">
        <span>Researcher's Workspace</span>
      </nav>
    </header>

    <main class="page">
      <section id="studio" class="studio-hero is-3d" aria-labelledby="studio-title">
        <div
          id="auraStudio3d"
          class="studio-3d"
          data-root-prefix="{{ root_prefix }}"
          aria-label="AURA realistic 3D researcher's workspace"
        >
          <div class="studio-3d-loading">
            <span>AURA Studio</span>
            <small>Entering the researcher's workspace</small>
          </div>
        </div>
        <div class="studio-copy">
          <p class="eyebrow">{{ date }}</p>
          <h1 id="studio-title" class="studio-wordmark">
            <span>AURA</span>
            <span>Studio</span>
          </h1>
          <p class="studio-role">Researcher's Workspace</p>
          <p class="studio-expansion">
            Advanced Understanding<br>
            of Research &amp; Applications
          </p>
        </div>
        <div class="studio-hint">Click objects in the room</div>
        <div class="studio-object-label" id="studioObjectLabel" aria-hidden="true"></div>
        <div class="studio-panel" id="studioPanel" aria-live="polite" aria-hidden="true">
          <button class="studio-panel-close" type="button" data-close-studio-panel aria-label="Close studio panel">×</button>
          <div class="studio-panel-content" id="studioPanelContent"></div>
        </div>
        <div class="research-desk studio-fallback" aria-label="Researcher's desk fallback navigation">
          <button class="desk-object desk-window" type="button" data-studio-target="future-signals" aria-label="Open Future Signals">
            <span class="window-frame"><i></i><i></i></span>
            <strong>Window</strong>
            <em>Future Signals</em>
          </button>
          <button class="desk-object desk-notebook" type="button" data-studio-target="key-insight" aria-label="Open Today's Key Insight">
            <span class="notebook-shape"><i></i></span>
            <strong>Notebook</strong>
            <em>Today's Key Insight</em>
          </button>
          <button class="desk-object desk-bookshelf" type="button" data-studio-target="opportunity-graph" aria-label="Open Material Opportunity Graph">
            <span class="bookshelf-shape"><i></i><i></i><i></i><i></i></span>
            <strong>Bookshelf</strong>
            <em>Material Opportunity Graph</em>
          </button>
          <button class="desk-object desk-palette" type="button" data-studio-target="suggested-actions" aria-label="Open Suggested Actions">
            <span class="palette-shape"><i></i><i></i><i></i><i></i></span>
            <strong>Palette</strong>
            <em>Suggested Actions</em>
          </button>
          <button class="desk-object desk-archive" type="button" data-studio-target="archives" aria-label="Open Archive">
            <span class="archive-shape"><i></i></span>
            <strong>Archive Box</strong>
            <em>Archive</em>
          </button>
          <button class="desk-object desk-cat" type="button" data-studio-target="insights" aria-label="Open Weekly Insights">
            <span class="cat-shape"><i></i><i></i></span>
            <strong>Cat</strong>
            <em>Weekly Insights</em>
          </button>
          <button class="desk-object desk-team-room" type="button" data-studio-target="team-room" aria-label="Open Team Room">
            <span class="team-room-shape"><i></i></span>
            <strong>Team Room</strong>
            <em>Members</em>
          </button>
        </div>
      </section>

      <section id="future-signals" class="opportunity-panel radar-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Window</p>
          <h2>Future Signals</h2>
        </div>
        <div class="hotspot-grid">
          {% for radar in future_radar %}
          <article class="future-signal-card">
            <strong>{{ radar.category }}</strong>
            <span>Future Signal {{ radar.avg_future_signal_score }} <button class="info-button compact" type="button" data-metric="future_signal_score" aria-label="查看Future Signal说明">ⓘ</button></span>
            <p>{{ radar.summary }}</p>
            <div class="signal-sources">
              {% for source in radar.sources %}
              <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">{{ source.source }} · 阅读原文</a>
              {% endfor %}
            </div>
          </article>
          {% else %}
          <article>
            <strong>暂无独立未来技术信号</strong>
            <span>未来信号不足时，AURA 不会用普通新闻填充窗外世界。</span>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="key-insight" class="opportunity-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Notebook</p>
          <h2>Today's Key Insight</h2>
        </div>
        <div class="insight-stack insight-panel">
          {% for row in research_insight_cards %}
          <article>
            <strong>{{ row.label }}</strong>
            <p>{{ row.text }}</p>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="opportunity-graph" class="opportunity-panel priority-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Bookshelf</p>
          <h2>Material Opportunity Graph</h2>
        </div>
        <div class="bookshelf-library" aria-label="Opportunity library">
          {% for domain in opportunity_library %}
          <details class="bookshelf-domain" {% if domain.is_default_open %}open{% endif %}>
            <summary>
              <span>
                <strong>{% if domain.count %}●{% else %}○{% endif %} {{ domain.domain }} ({{ domain.count }})</strong>
                <em>{{ domain.zh }}</em>
                {% if domain.description %}
                <small>{{ domain.description }}</small>
                {% endif %}
              </span>
              <b>{{ domain.count }} 本周期新增</b>
            </summary>
            <div class="bookshelf-current-list">
              {% for item in domain["items"] %}
              <article class="bookshelf-current-item">
                <h3>{{ item.title }}</h3>
                <dl>
                  <div><dt>来源</dt><dd>{{ item.source }}</dd></div>
                  <div><dt>发布时间</dt><dd>{{ item.published_date }}</dd></div>
                </dl>
                {% if item.url %}
                <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.link_label }}</a>
                {% endif %}
              </article>
              {% else %}
              <p class="empty-library">本周期暂无新增内容。</p>
              {% endfor %}
            </div>
          </details>
          {% endfor %}
        </div>
      </section>

      <section id="suggested-actions" class="opportunity-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Palette</p>
          <h2>Suggested Actions</h2>
        </div>
        <div class="validation-pool">
          {% for group in validation_pool %}
          <article style="--action-color: {{ group.color }}">
            <h3>{{ group.action }}</h3>
            <span>{% if group.has_new %}<i class="action-dot" aria-label="本周期有新增内容"></i>{% endif %}{{ group.meaning }} · {{ group.count }} 个机会</span>
            <div class="palette-brief">
              <p><strong>AI Insight</strong>{{ group.ai_insight }}</p>
              <p><strong>Why Now</strong>{{ group.why_now }}</p>
              <p><strong>Suggested Move</strong>{{ group.suggested_move }}</p>
            </div>
            <div class="palette-evidence">
              <strong>Evidence</strong>
              {% for source in group.evidence %}
              <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">
                <span>{{ source.title }}</span>
                <em>{{ source.source }} · 阅读来源</em>
              </a>
              {% else %}
              <span>暂无足够来源证据。</span>
              {% endfor %}
            </div>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="insights" class="opportunity-panel insights-panel studio-content-source">
        <div class="section-heading">
          <p class="eyebrow">Cat</p>
          <h2>Weekly Insights</h2>
        </div>
        <div class="insights-grid">
          {% for article in insights %}
          <article>
            <div class="insight-meta">{{ article.source }} · {{ article.reading_time }}</div>
            <h3><a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a></h3>
            <p><strong>为什么值得读：</strong>{{ article.why_read }}</p>
            <p><strong>建议关注：</strong>{{ article.focus }}</p>
            <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">阅读全文</a>
          </article>
          {% else %}
          <article>
            <div class="insight-meta">内容池</div>
            <h3>Insights 内容池尚未配置</h3>
            <p><strong>为什么值得读：</strong>该模块用于沉淀帮助研发人员理解变化背后原因的深度文章。</p>
            <p><strong>建议关注：</strong>后续可从本地 JSON 或自动化来源补充精选内容。</p>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="archives" class="archive-grid studio-content-source">
        {% if archives.reset %}
        <div class="workspace-history archive-reset-state">
          <p class="eyebrow">Archive</p>
          <h2>{{ archives.message_en }}</h2>
          <p>{{ archives.message_zh }}</p>
        </div>
        {% else %}
        <div class="workspace-history">
          <p class="eyebrow">Dynamic Workspace</p>
          <h2>Workspace Archive</h2>
          {% for cycle in archives.workspace %}
          <details class="workspace-cycle" {% if loop.first %}open{% endif %}>
            <summary>{{ cycle.date }}</summary>
            <div class="workspace-cycle-grid">
              <article>
                <strong>Window / Future Signals</strong>
                {% for signal in cycle.window %}
                <span>{{ signal.category }} · Future Signal {{ signal.avg_future_signal_score }}</span>
                <span>{{ signal.summary }}</span>
                {% for source in signal.sources %}
                <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">{{ source.source }} · 阅读原文</a>
                {% endfor %}
                {% else %}
                <span>本周期暂无未来信号。</span>
                {% endfor %}
              </article>
              <article>
                <strong>Notebook / Today's Key Insight</strong>
                {% for row in cycle.notebook %}
                <span>{{ row.label }}：{{ row.text }}</span>
                {% endfor %}
              </article>
              <article>
                <strong>Cat / Weekly Insights</strong>
                {% for article in cycle.cat %}
                <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.source }} · {{ article.title }}</a>
                {% else %}
                <span>本周期暂无精选长读。</span>
                {% endfor %}
              </article>
              <article>
                <strong>Palette / Suggested Actions</strong>
                {% for group in cycle.palette %}
                <span>{{ group.action }}：{{ group.suggested_move }}</span>
                {% for source in group.evidence %}
                <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">{{ source.source }} · {{ source.title }}</a>
                {% endfor %}
                {% else %}
                <span>本周期暂无行动建议。</span>
                {% endfor %}
              </article>
              <article>
                <strong>Bookshelf / Material Opportunity Graph</strong>
                {% for domain in cycle.bookshelf %}
                <span>{{ domain.domain }} · {{ domain.count }} 条</span>
                {% for item in domain["items"] %}
                <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a>
                {% endfor %}
                {% else %}
                <span>本周期暂无材料机会入架。</span>
                {% endfor %}
              </article>
            </div>
          </details>
          {% else %}
          <p class="empty-library">暂无历史工作区快照。</p>
          {% endfor %}
        </div>
        <div>
          <p class="eyebrow">Archive</p>
          <h2>Daily Archive</h2>
          <div class="archive-links">
            {% for item in archives.daily %}
            <a href="{{ item.href }}">{{ item.date }}</a>
            {% endfor %}
          </div>
        </div>
        <div>
          <p class="eyebrow">Monthly</p>
          <h2>Monthly Archive</h2>
          <div class="archive-links">
            {% for item in archives.monthly %}
            <a href="{{ item.href }}">{{ item.month }}</a>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </section>

      <section id="team-room" class="team-room-panel studio-content-source">
        <div class="team-room-inner">
          <div class="section-heading">
            <p class="eyebrow">Team Room</p>
          </div>
          <div class="team-room-scene" aria-label="Team members">
            <button class="team-room-member" type="button" data-team-profile="gou-zhi">
              <img src="{{ asset_prefix }}/team-gou-zhi.png" alt="苟智">
              <strong>苟智</strong>
              <span>Active</span>
            </button>
            <button class="team-room-member is-center" type="button" data-team-profile="zhou-qiang">
              <img src="{{ asset_prefix }}/team-zhou-qiang.png" alt="周强">
              <strong>周强</strong>
              <span>Former Member</span>
            </button>
            <button class="team-room-member" type="button" data-team-profile="liang-yunqi">
              <img src="{{ asset_prefix }}/team-liang-yunqi.png" alt="梁蕴祺">
              <strong>梁蕴祺</strong>
              <span>Active</span>
            </button>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <strong>{{ brand_en }}</strong>
      <span>{{ brand_full_en }}</span>
    </footer>

    <script>
      window.AURA = { generatedAt: "{{ date }}" };
    </script>
    <script>
      (() => {
        const panel = document.getElementById("studioPanel");
        const panelContent = document.getElementById("studioPanelContent");
        const sources = new Map(
          [...document.querySelectorAll(".studio-content-source")].map((node) => [node.id, node])
        );
        if (!panel || !panelContent) return;

        const teamProfiles = {
          "zhou-qiang": {
            name: "周强",
            status: "Former Member",
            role: "",
            joined: "",
            expertise: "",
            experience: ""
          },
          "gou-zhi": {
            name: "苟智",
            status: "Active",
            role: "",
            joined: "",
            expertise: "",
            experience: ""
          },
          "liang-yunqi": {
            name: "梁蕴祺",
            status: "Active",
            role: "",
            joined: "",
            expertise: "",
            experience: ""
          }
        };

        const escapeHtml = (value) => String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");

        const openPanel = (target) => {
          const source = sources.get(target);
          if (!source) return;
          panelContent.innerHTML = source.innerHTML;
          panel.dataset.source = target;
          panel.classList.add("is-open");
          panel.setAttribute("aria-hidden", "false");
        };

        const openProfile = (id) => {
          const profile = teamProfiles[id];
          if (!profile) return;
          panelContent.innerHTML = `
            <section class="team-profile-card">
              <p class="eyebrow">Team Room</p>
              <div class="team-profile-head">
                <h2>${escapeHtml(profile.name)}</h2>
                <span class="member-status ${profile.status === "Active" ? "is-active" : "is-former"}">${escapeHtml(profile.status)}</span>
              </div>
              <dl>
                <div><dt>职位</dt><dd>${escapeHtml(profile.role)}</dd></div>
                <div><dt>加入时间</dt><dd>${escapeHtml(profile.joined)}</dd></div>
                <div><dt>专业方向</dt><dd>${escapeHtml(profile.expertise)}</dd></div>
                <div><dt>经历</dt><dd>${escapeHtml(profile.experience)}</dd></div>
              </dl>
            </section>
          `;
          panel.dataset.source = `team-${id}`;
          panel.classList.add("is-open");
          panel.setAttribute("aria-hidden", "false");
        };

        const closePanel = () => {
          panel.classList.remove("is-open");
          panel.setAttribute("aria-hidden", "true");
        };

        window.AURAStudioOpenPanel = openPanel;
        window.AURAStudioOpenProfile = openProfile;
        document.querySelectorAll("[data-studio-target]").forEach((button) => {
          button.addEventListener("click", () => openPanel(button.dataset.studioTarget));
        });
        document.addEventListener("click", (event) => {
          const memberButton = event.target.closest("[data-team-profile]");
          if (memberButton) openProfile(memberButton.dataset.teamProfile);
        });
        document.querySelector("[data-close-studio-panel]")?.addEventListener("click", closePanel);
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") closePanel();
        });
      })();
    </script>
    <script type="module" src="{{ asset_prefix }}/studio3d.js?v=20260628-team-room-v3"></script>
    {% include "_metric_modal.html.j2" %}
  </body>
</html>
