<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ brand_en }}</title>
    <link rel="stylesheet" href="{{ asset_prefix }}/style.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="{{ root_prefix }}/index.html">
        <span>{{ brand_en }}</span>
      </a>
      <nav class="top-nav">
        <a href="#learning-start">Home</a>
        <a href="#opportunity-graph">Material Library</a>
        <a href="#future-signals">Future Signals</a>
        <a href="#insights">Weekly Insights</a>
        <a href="#archives">Archive</a>
        <a href="#team-room">Team Room</a>
      </nav>
    </header>

    <main class="page learning-home">
      <section id="learning-start" class="learning-hero" aria-labelledby="learning-title">
        <div class="learning-hero-copy">
          <p class="eyebrow">{{ date }}</p>
          <h1 id="learning-title">AURA</h1>
          <p class="learning-subtitle">Materials Intelligence &amp; Future Learning Platform</p>
          <p class="learning-question">What would you like to explore today?</p>
        </div>

        <div class="learning-entry-grid" aria-label="AURA learning entries">
          <a class="learning-entry-card is-opportunity" href="#discover-opportunities">
            <span class="entry-icon" aria-hidden="true">01</span>
            <strong>Discover Opportunities</strong>
            <em>发现材料机会</em>
            <small>Today's Key Insight / Material Library / Suggested Actions</small>
          </a>
          <a class="learning-entry-card is-future" href="#explore-future-trends">
            <span class="entry-icon" aria-hidden="true">02</span>
            <strong>Explore Future Trends</strong>
            <em>了解未来趋势</em>
            <small>Future Signals</small>
          </a>
          <a class="learning-entry-card is-thinking" href="#upgrade-your-thinking">
            <span class="entry-icon" aria-hidden="true">03</span>
            <strong>Upgrade Your Thinking</strong>
            <em>拓展认知与思维</em>
            <small>Weekly Insights</small>
          </a>
          <a class="learning-entry-card is-review" href="#review-knowledge">
            <span class="entry-icon" aria-hidden="true">04</span>
            <strong>Review Knowledge</strong>
            <em>查看历史沉淀</em>
            <small>Archive</small>
          </a>
        </div>
      </section>

      <section id="discover-opportunities" class="learning-module studio-content-source">
        <div class="learning-module-heading">
          <p class="eyebrow">01 Discover Opportunities</p>
          <h2>发现材料机会</h2>
        </div>

        <section id="key-insight" class="opportunity-panel">
          <div class="section-heading">
            <p class="eyebrow">Today's Key Insight</p>
            <h2>Today's Key Insight</h2>
          </div>
          <div class="insight-stack insight-panel">
            {% for row in research_insight_cards %}
            <article>
              <strong>{{ row.label }}</strong>
              <p>{{ row.text }}</p>
            </article>
            {% endfor %}
          </div>
        </section>

        <section id="opportunity-graph" class="opportunity-panel priority-panel">
          <div class="section-heading">
            <p class="eyebrow">Material Library</p>
            <h2>Material Library</h2>
          </div>
          <div class="material-course-grid" aria-label="Material Library categories">
            {% for domain in opportunity_library %}
            <details class="material-course-card" {% if domain.is_default_open %}open{% endif %}>
              <summary>
                <span class="course-card-main">
                  <strong>{{ domain.domain }}</strong>
                  <em>{{ domain.zh }}</em>
                </span>
                <span class="course-card-meta">
                  <b>{{ domain.count }}</b>
                  <small>本期新增</small>
                </span>
                <span class="course-card-action">进入</span>
              </summary>
              <div class="material-course-list">
                {% for item in domain["items"] %}
                <article class="material-course-item">
                  <h3>{{ item.title }}</h3>
                  <p>{{ item.brief }}</p>
                  <div class="course-item-meta">
                    <span>{{ item.source }}</span>
                    <span>{{ item.published_date }}</span>
                  </div>
                  {% if item.url %}
                  <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.link_label }}</a>
                  {% endif %}
                </article>
                {% else %}
                <p class="empty-library">本周期暂无新增内容。</p>
                {% endfor %}
              </div>
            </details>
            {% endfor %}
          </div>
        </section>

        <section id="suggested-actions" class="opportunity-panel">
          <div class="section-heading">
            <p class="eyebrow">Suggested Actions</p>
            <h2>Suggested Actions</h2>
          </div>
          <div class="validation-pool">
            {% if validation_pool | selectattr("count") | list %}
            {% for group in validation_pool %}
            <article style="--action-color: {{ group.color }}">
              <h3>{{ group.action }}</h3>
              <span>{% if group.has_new %}<i class="action-dot" aria-label="本周期有新增内容"></i>{% endif %}{{ group.meaning }} · {{ group.count }} 个机会</span>
              <div class="palette-brief">
                <p><strong>AI Insight</strong>{{ group.ai_insight }}</p>
                <p><strong>Why Now</strong>{{ group.why_now }}</p>
                <p><strong>Suggested Move</strong>{{ group.suggested_move }}</p>
              </div>
              <div class="palette-evidence">
                <strong>Evidence</strong>
                {% for source in group.evidence %}
                <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">
                  <span>{{ source.title }}</span>
                  <em>{{ source.source }} · 阅读来源</em>
                </a>
                {% else %}
                <span>暂无足够来源证据。</span>
                {% endfor %}
              </div>
            </article>
            {% endfor %}
            {% else %}
            <article>
              <h3>本期暂无可生成建议的有效信号。</h3>
              <span>Palette 只在有足够证据时生成研发建议。</span>
            </article>
            {% endif %}
          </div>
        </section>
      </section>

      <section id="explore-future-trends" class="learning-module studio-content-source">
        <div class="learning-module-heading">
          <p class="eyebrow">02 Explore Future Trends</p>
          <h2>了解未来趋势</h2>
        </div>
        <section id="future-signals" class="opportunity-panel radar-panel">
          <div class="section-heading">
            <p class="eyebrow">Future Signals</p>
            <h2>Future Signals</h2>
          </div>
          <div class="hotspot-grid">
            {% for radar in future_radar %}
            <article class="future-signal-card">
              <strong>{{ radar.category }}</strong>
              <span>Future Signal {{ radar.avg_future_signal_score }} <button class="info-button compact" type="button" data-metric="future_signal_score" aria-label="查看Future Signal说明">ⓘ</button></span>
              <p>{{ radar.summary }}</p>
              <div class="signal-sources">
                {% for source in radar.sources %}
                <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">{{ source.source }} · 阅读原文</a>
                {% endfor %}
              </div>
            </article>
            {% else %}
            <article>
              <strong>本期暂无 Future Signals。</strong>
              <span>未来信号不足时，AURA 不会用普通新闻填充窗外世界。</span>
            </article>
            {% endfor %}
          </div>
        </section>
      </section>

      <section id="upgrade-your-thinking" class="learning-module studio-content-source">
        <div class="learning-module-heading">
          <p class="eyebrow">03 Upgrade Your Thinking</p>
          <h2>拓展认知与思维</h2>
        </div>
        <section id="insights" class="opportunity-panel insights-panel">
          <div class="section-heading">
            <p class="eyebrow">Weekly Insights</p>
            <h2>Weekly Insights</h2>
          </div>
          <div class="insights-grid">
            {% for article in insights %}
            <article>
              <div class="insight-meta">{{ article.source }} · {{ article.reading_time }}</div>
              <h3><a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a></h3>
              <p><strong>推荐理由：</strong>{{ article.why_read }}</p>
              <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">阅读全文</a>
            </article>
            {% else %}
            <article>
              <div class="insight-meta">Weekly Insights</div>
              <h3>本期暂无 Weekly Insights。</h3>
              <p>Weekly Insights 只展示本期确认过的深度阅读内容。</p>
            </article>
            {% endfor %}
          </div>
        </section>
      </section>

      <section id="review-knowledge" class="learning-module studio-content-source">
        <div class="learning-module-heading">
          <p class="eyebrow">04 Review Knowledge</p>
          <h2>查看历史沉淀</h2>
        </div>

      <section id="archives" class="archive-grid">
        {% if archives.reset %}
        <div class="workspace-history archive-reset-state">
          <p class="eyebrow">Archive</p>
          <h2>{{ archives.message_en }}</h2>
          <p>{{ archives.message_zh }}</p>
        </div>
        {% else %}
        <div class="workspace-history">
          <p class="eyebrow">Research Briefs</p>
          <h2>Latest Brief Archive</h2>
          {% for cycle in archives.workspace %}
          <details class="workspace-cycle" {% if loop.first %}open{% endif %}>
            <summary>{{ cycle.date }}</summary>
            <div class="workspace-cycle-grid">
              <article>
                <strong>Future Signals</strong>
                {% for signal in cycle.window %}
                <span>{{ signal.category }} · Future Signal {{ signal.avg_future_signal_score }}</span>
                <span>{{ signal.summary }}</span>
                {% for source in signal.sources %}
                <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">{{ source.source }} · 阅读原文</a>
                {% endfor %}
                {% else %}
                <span>本周期暂无未来信号。</span>
                {% endfor %}
              </article>
              <article>
                <strong>Today's Key Insight</strong>
                {% for row in cycle.notebook %}
                <span>{{ row.label }}：{{ row.text }}</span>
                {% endfor %}
              </article>
              <article>
                <strong>Weekly Insights</strong>
                {% for article in cycle.cat %}
                <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.source }} · {{ article.title }}</a>
                {% else %}
                <span>本周期暂无精选长读。</span>
                {% endfor %}
              </article>
              <article>
                <strong>Suggested Actions</strong>
                {% for group in cycle.palette %}
                <span>{{ group.action }}：{{ group.suggested_move }}</span>
                {% for source in group.evidence %}
                <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">{{ source.source }} · {{ source.title }}</a>
                {% endfor %}
                {% else %}
                <span>本周期暂无行动建议。</span>
                {% endfor %}
              </article>
              <article>
                <strong>Material Library</strong>
                {% for domain in cycle.bookshelf %}
                <span>{{ domain.domain }} · {{ domain.count }} 条</span>
                {% for item in domain["items"] %}
                <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a>
                {% endfor %}
                {% else %}
                <span>本周期暂无材料机会入架。</span>
                {% endfor %}
              </article>
            </div>
          </details>
          {% else %}
          <p class="empty-library">暂无历史工作区快照。</p>
          {% endfor %}
        </div>
        <div>
          <p class="eyebrow">Archive</p>
          <h2>Browse by Date</h2>
          <div class="archive-tree">
            {% for year in archives.tree %}
            <details class="archive-year" {% if loop.first %}open{% endif %}>
              <summary>{{ year.year }}</summary>
              {% for month in year.months %}
              <details class="archive-month" {% if loop.first %}open{% endif %}>
                <summary>{{ month.month }}</summary>
                <div class="archive-links">
                  {% for item in month.days %}
                  <a href="{{ item.href }}">{{ item.date }}</a>
                  {% endfor %}
                </div>
              </details>
              {% endfor %}
            </details>
            {% else %}
            <p class="empty-library">归档已重置，等待新的 AURA 记录。</p>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </section>
      </section>

      <section id="team-room" class="team-room-panel studio-content-source">
        <div class="team-room-inner">
          <div class="section-heading">
            <p class="eyebrow">Team Room</p>
          </div>
          <div class="team-room-scene" aria-label="Team members">
            <button class="team-room-member" type="button" data-team-profile="gou-zhi">
              <img src="{{ asset_prefix }}/team-gou-zhi.png" alt="苟智">
              <strong>苟智</strong>
              <span>Active</span>
            </button>
            <button class="team-room-member is-center" type="button" data-team-profile="zhou-qiang">
              <img src="{{ asset_prefix }}/team-zhou-qiang.png" alt="周强">
              <strong>周强</strong>
              <span>Former Member</span>
            </button>
            <button class="team-room-member" type="button" data-team-profile="liang-yunqi">
              <img src="{{ asset_prefix }}/team-liang-yunqi.png" alt="梁蕴祺">
              <strong>梁蕴祺</strong>
              <span>Active</span>
            </button>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <strong>{{ brand_en }}</strong>
      <span>{{ brand_full_en }}</span>
    </footer>

    <script>
      window.AURA = { generatedAt: "{{ date }}" };
    </script>
    {% include "_metric_modal.html.j2" %}
  </body>
</html>
