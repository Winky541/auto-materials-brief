<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ brand_en }} | {{ brand_cn }}</title>
    <link rel="stylesheet" href="/auto-materials-brief/assets/style.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="{{ root_prefix }}/index.html">
        <span>{{ brand_en }}</span>
        <small>{{ brand_cn }}</small>
      </a>
      <nav class="top-nav">
        <a href="#judgement">Research Insight</a>
        <a href="#brief">Highlights</a>
        <a href="#opportunity-graph">Material Opportunity Graph</a>
        <a href="#company-intelligence">Company Intelligence</a>
        <a href="#patents-research">Patents & Research</a>
        <a href="#future-radar">Future Technology Radar</a>
        <a href="#validation-pool">Validation Pipeline</a>
        <a href="#insights">Insights</a>
        <a href="#archives">Archive</a>
      </nav>
    </header>

    <main class="page">
      <section id="judgement" class="hero">
        <div>
          <p class="eyebrow">{{ date }}</p>
          <h1>{{ brand_en }}</h1>
          <p class="subtitle">{{ brand_cn }}</p>
          <p class="subtitle small-subtitle">{{ brand_full_en }}</p>
          <p class="motto">帮助研发人员理解变化、发现机会、建立储备。当未来到来的时候，我们已经准备好了。</p>
        </div>
        <div class="hero-note">
          <span>Today’s Key Insight</span>
          <div class="insight-stack">
            {% for row in research_insight_cards %}
            <article>
              <strong>{{ row.label }}</strong>
              <p>{{ row.text }}</p>
            </article>
            {% endfor %}
          </div>
        </div>
      </section>

      <section id="brief" class="opportunity-panel">
        <div class="section-heading">
          <p class="eyebrow">Today Highlights</p>
          <h2>今日重点观察</h2>
        </div>
        <div class="highlight-list">
          {% for item in items[:5] %}
          <article>
            <span>{{ item.source }} · {{ item.published_date }}</span>
            <h3><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></h3>
            <p>Material Opportunity <button class="info-button compact" type="button" data-metric="material_opportunity" aria-label="查看Material Opportunity说明">ⓘ</button>: {{ item.material_opportunity }}</p>
            <strong>Suggested Action <button class="info-button compact" type="button" data-metric="suggested_action" aria-label="查看Suggested Action说明">ⓘ</button>: {{ item.suggested_action_en }} / {{ item.suggested_action_zh }}</strong>
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">阅读原文</a>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="opportunity-graph" class="opportunity-panel priority-panel">
        <div class="section-heading">
          <p class="eyebrow">Material Opportunity Graph</p>
          <h2>Material Opportunity Graph</h2>
          <p class="section-note">AURA 的核心资产。产业和技术只是信号，材料机会才是最终沉淀。</p>
        </div>
        <div class="domain-grid">
          {% for domain in opportunity_domains %}
          <article>
            <strong>{{ domain.domain }}</strong>
            <p>{{ domain.zh }}</p>
            <span>{{ domain.news_count }} signals · {{ domain.topic_count }} topics</span>
          </article>
          {% endfor %}
        </div>
        <div class="topic-grid">
          {% for topic in opportunity_topics[:8] %}
          <article>
            <div class="topic-topline">
              <span>{{ topic.domain }}</span>
              <b>{{ topic.validation_priority }} <button class="info-button compact" type="button" data-metric="validation_priority" aria-label="查看Validation Priority说明">ⓘ</button></b>
            </div>
            <h3>{{ topic.topic }}</h3>
            <p>
              Material Value {{ topic.material_value }}
              <button class="info-button compact" type="button" data-metric="material_value" aria-label="查看Material Value说明">ⓘ</button>
              · {{ topic.suggested_action }}
              <button class="info-button compact" type="button" data-metric="suggested_action" aria-label="查看Suggested Action说明">ⓘ</button>
            </p>
            <div class="related-signal-list">
              {% for signal in topic.related_signals %}
              <a href="{{ signal.url }}" target="_blank" rel="noopener noreferrer">{{ signal.title }}</a>
              {% endfor %}
            </div>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="emerging-opportunities" class="opportunity-panel compact-panel">
        <div class="section-heading">
          <p class="eyebrow">Emerging Material Opportunities</p>
          <h2>Emerging Material Opportunities</h2>
        </div>
        <div class="hotspot-grid">
          {% for topic in emerging_topics %}
          <article>
            <span class="new-pill">NEW</span>
            <strong>{{ topic.topic }}</strong>
            <span>{{ topic.domain }} · {{ topic.suggested_action }} <button class="info-button compact" type="button" data-metric="suggested_action" aria-label="查看Suggested Action说明">ⓘ</button></span>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="company-intelligence" class="opportunity-panel">
        <div class="section-heading">
          <p class="eyebrow">Company Intelligence</p>
          <h2>企业技术动态</h2>
        </div>
        <div class="hotspot-grid">
          {% for row in company_intelligence %}
          <article>
            <strong>{{ row.company }}</strong>
            <span>{{ row.count }} 条相关情报</span>
          </article>
          {% else %}
          <article>
            <strong>暂无重点企业信号</strong>
            <span>等待更多真实来源进入候选池</span>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="patents-research" class="opportunity-panel">
        <div class="section-heading">
          <p class="eyebrow">Patents & Research</p>
          <h2>专利与论文</h2>
        </div>
        <div class="validation-pool">
          {% for label, group_items in patents_research.items() %}
          <article>
            <h3>{{ label }}</h3>
            <span>{{ group_items | length }} 条</span>
            <ul>
              {% for item in group_items[:3] %}
              <li><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></li>
              {% else %}
              <li>暂无</li>
              {% endfor %}
            </ul>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="future-radar" class="opportunity-panel radar-panel">
        <div class="section-heading">
          <p class="eyebrow">Future Technology Radar</p>
          <h2>未来技术雷达</h2>
          <p class="section-note">未来技术仅作为雷达信号，只有当它能回到汽车产业意义、先进材料意义和验证机会时才进入页面展示。</p>
        </div>
        <div class="hotspot-grid">
          {% for radar in future_radar %}
          <article>
            <strong>{{ radar.category }}</strong>
            <span>{{ radar.count }} 条 · Future Signal {{ radar.avg_future_signal_score }} <button class="info-button compact" type="button" data-metric="future_signal_score" aria-label="查看Future Signal说明">ⓘ</button></span>
          </article>
          {% else %}
          <article>
            <strong>暂无独立未来技术信号</strong>
            <span>未来技术模块只在能回答材料机会时展示</span>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="validation-pool" class="opportunity-panel">
        <div class="section-heading">
          <p class="eyebrow">Validation Pipeline</p>
          <h2>验证储备池</h2>
        </div>
        <div class="validation-pool">
          {% for group in validation_pool %}
          <article>
            <h3>{{ group.action }}</h3>
            <span>{{ group.count }} 条</span>
            <ul>
              {% for item in group["items"][:4] %}
              <li><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></li>
              {% else %}
              <li>暂无</li>
              {% endfor %}
            </ul>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="insights" class="opportunity-panel insights-panel">
        <div class="section-heading">
          <p class="eyebrow">Insights</p>
          <h2>Insights</h2>
          <p class="section-note">帮助理解变化背后的原因。这里先展示人工精选深度文章，后续可接入自动化采集与筛选。</p>
        </div>
        <div class="insights-grid">
          {% for article in insights %}
          <article>
            <div class="insight-meta">{{ article.reading_time }}</div>
            <h3><a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a></h3>
            <p><strong>为什么值得读：</strong>{{ article.why_read }}</p>
            <p><strong>建议关注：</strong>{{ article.focus }}</p>
            <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">阅读全文</a>
          </article>
          {% else %}
          <article>
            <div class="insight-meta">待补充</div>
            <h3>Insights 内容池尚未配置</h3>
            <p><strong>为什么值得读：</strong>该模块用于沉淀帮助研发人员理解变化背后原因的深度文章。</p>
            <p><strong>建议关注：</strong>后续可从本地 JSON 或自动化来源补充精选内容。</p>
          </article>
          {% endfor %}
        </div>
      </section>

      <section id="archives" class="archive-grid">
        <div>
          <p class="eyebrow">Archive</p>
          <h2>历史归档</h2>
          <div class="archive-links">
            {% for item in archives.daily %}
            <a href="{{ item.href }}">{{ item.date }}</a>
            {% endfor %}
          </div>
        </div>
        <div>
          <p class="eyebrow">Monthly</p>
          <h2>月度归档</h2>
          <div class="archive-links">
            {% for item in archives.monthly %}
            <a href="{{ item.href }}">{{ item.month }}</a>
            {% endfor %}
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <strong>{{ brand_en }}</strong>
      <span>{{ brand_full_en }}</span>
    </footer>

    <script>
      window.AURA = { generatedAt: "{{ date }}" };
    </script>
    {% include "_metric_modal.html.j2" %}
  </body>
</html>
