<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ date }} | {{ brand_en }}</title>
    <link rel="stylesheet" href="/auto-materials-brief/assets/style.css">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="{{ root_prefix }}/index.html">
        <span>{{ brand_en }}</span>
        <small>{{ brand_cn }}</small>
      </a>
      <nav class="top-nav">
        <a href="{{ root_prefix }}/index.html">首页</a>
        <a href="#brief">每日精选</a>
      </nav>
    </header>

    <main class="page narrow-page">
      <section class="archive-hero">
        <p class="eyebrow">Daily Archive</p>
        <h1>{{ date }} 研究简报</h1>
        <p>{{ insight }}</p>
      </section>

      <section id="brief" class="content single-column">
        {% include "_news_cards.html.j2" %}
      </section>
    </main>
  </body>
</html>
